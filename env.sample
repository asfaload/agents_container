# Set specific user name here if needed
export USER_NAME=${USER_NAME:-$(id -u -n)}
export USER_ID=${USER_ID:-$(id -u)}
export USER_GROUP=${USER_GROUP:-$(id -g)}

# Docker image name that is build
export IMAGE_NAME=${IMAGE_NAME:-ai_agents_${USER_NAME}}

# Privacy configuration
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1  # Don't send telemetry data

